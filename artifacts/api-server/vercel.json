{
  "framework": null,
  "buildCommand": "cd ../.. && pnpm install && pnpm run typecheck && pnpm -r --filter \"./artifacts/api-server\" run build",
  "outputDirectory": "dist",
  "installCommand": "cd ../.. && pnpm install --frozen-lockfile",
  "env": {
    "NODE_ENV": "production"
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "functions": {
    "dist/index.mjs": {
      "runtime": "nodejs20.x",
      "maxDuration": 60
    }
  }
}
