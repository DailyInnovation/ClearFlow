{
  "version": 3,
  "buildCommand": "pnpm install --frozen-lockfile && pnpm run build",
  "outputDirectory": "artifacts/checklist/dist/public",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "handle": "filesystem" },
    { "src": "/.*", "dest": "/index.html" }
  ],
  "env": {
    "NODE_ENV": "production"
  }
}
